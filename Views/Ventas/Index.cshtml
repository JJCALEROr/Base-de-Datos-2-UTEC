@model InventarioVentasMVC.ViewModels.VentaViewModel

@{
    ViewData["Title"] = "POS Ventas";
}

<h1>POS - Ventas</h1>

<hr />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="row">

    <!-- DATOS VENTA -->
    <div class="col-md-4">

        <div class="card p-3 mb-3">

            <h4>Datos Venta</h4>

            <!-- FORMULARIO FINAL -->
            <form asp-action="ConfirmarVenta" method="post">

                <div class="form-group mb-3">
                    <label>Cliente</label>

                    <select name="clienteId"
                            class="form-control"
                            required
                            asp-items="ViewBag.ClienteId">
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label>Usuario</label>

                    <select name="usuarioId"
                            class="form-control"
                            required
                            asp-items="ViewBag.UsuarioId">
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label>Descuento</label>

                    <input type="number"
                           step="0.01"
                           name="descuento"
                           class="form-control"
                           value="0" />
                </div>

                <div class="form-group mb-3">
                    <label>Observaciones</label>

                    <textarea name="observaciones"
                              class="form-control">
                    </textarea>
                </div>

                <h4 class="text-end">

                    Total:
                    @Model.Carrito.Sum(x => x.Subtotal).ToString("C")

                </h4>

                <button type="submit"
                        class="btn btn-success w-100">

                    Confirmar Venta

                </button>

            </form>

        </div>

    </div>

    <!-- CARRITO -->
    <div class="col-md-8">

        <!-- AGREGAR PRODUCTOS -->
        <div class="card p-3 mb-3">

            <h4>Agregar Producto</h4>

            <form asp-action="AgregarProducto" method="post">

                <div class="row">

                    <div class="col-md-6">

                        <label>Producto</label>

                        <select name="productoId"
                                class="form-control">

                            @foreach (var producto in ViewBag.Productos)
                            {
                                <option value="@producto.ProductoId">

                                    @producto.Nombre
                                    - Stock: @producto.Stock
                                    - Precio: @producto.PrecioVenta

                                </option>
                            }

                        </select>

                    </div>

                    <div class="col-md-3">

                        <label>Cantidad</label>

                        <input type="number"
                               name="cantidad"
                               class="form-control"
                               min="1"
                               value="1" />

                    </div>

                    <div class="col-md-3 d-flex align-items-end">

                        <button type="submit"
                                class="btn btn-primary w-100">

                            Agregar

                        </button>

                    </div>

                </div>

            </form>

        </div>

        <!-- TABLA CARRITO -->
        <div class="card p-3">

            <h4>Carrito</h4>

            <table class="table table-bordered">

                <thead>

                    <tr>
                        <th>Producto</th>
                        <th>Precio</th>
                        <th>Cantidad</th>
                        <th>Subtotal</th>
                        <th>Acciones</th>
                    </tr>

                </thead>

                <tbody>

                    @if (Model.Carrito.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center">
                                Carrito vacío
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model.Carrito)
                    {
                        <tr>

                            <td>@item.Producto</td>

                            <td>
                                @item.Precio.ToString("C")
                            </td>

                            <td>
                                @item.Cantidad
                            </td>

                            <td>
                                @item.Subtotal.ToString("C")
                            </td>

                            <td>

                                <a asp-action="EliminarProducto"
                                   asp-route-productoId="@item.ProductoId"
                                   class="btn btn-danger btn-sm">

                                    Eliminar

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

        <form asp-action="FinalizarVenta" method="post">
    
    <div class="row mt-3">

        <div class="col-md-3">
            <label>Cliente</label>
            <select asp-for="ClienteId"
                    asp-items="ViewBag.ClienteId"
                    class="form-control">
            </select>
        </div>

        <div class="col-md-3">
            <label>Usuario</label>
            <select asp-for="UsuarioId"
                    asp-items="ViewBag.UsuarioId"
                    class="form-control">
            </select>
        </div>

        <div class="col-md-2">
            <label>Descuento</label>
            <input asp-for="Descuento"
                   class="form-control"
                   value="0" />
        </div>

        <div class="col-md-4">
            <label>Observaciones</label>
            <input asp-for="Observaciones"
                   class="form-control" />
        </div>

    </div>

    <button type="submit"
            class="btn btn-success mt-3">
        Finalizar Venta
    </button>

</form>

    </div>

</div>