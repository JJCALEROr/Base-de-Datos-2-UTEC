<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - InventarioVentasMVC
    </title>

    <script type="importmap"></script>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/InventarioVentasMVC.styles.css"
          asp-append-version="true" />
</head>

<body style="padding-top: 70px;">

    <header>

        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow fixed-top">

            <div class="container-fluid">

                <a class="navbar-brand"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">

                    Inventario & Ventas SV |

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <!-- ========================================= -->
                    <!-- MENÚ IZQUIERDA -->
                    <!-- ========================================= -->

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">

                            <a class="nav-link text-white"
                               asp-controller="Home"
                               asp-action="Index">

                                Inicio

                            </a>

                        </li>

                        <!-- ========================================= -->
                        <!-- PRODUCTOS -->
                        <!-- ========================================= -->

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">

                                <a class="nav-link text-white"
                                   asp-controller="Productos"
                                   asp-action="Index">

                                    Productos

                                </a>

                            </li>
                        }

                        <!-- ========================================= -->
                        <!-- CATEGORÍAS -->
                        <!-- ========================================= -->

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">

                                <a class="nav-link text-white"
                                   asp-controller="Categorias"
                                   asp-action="Index">

                                    Categorías

                                </a>

                            </li>
                        }

                        <!-- ========================================= -->
                        <!-- USUARIOS -->
                        <!-- ========================================= -->

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">

                                <a class="nav-link text-white"
                                   asp-controller="Usuarios"
                                   asp-action="Index">

                                    Usuarios

                                </a>

                            </li>
                        }

                        <!-- ========================================= -->
                        <!-- CLIENTES -->
                        <!-- ========================================= -->

                        @if (
                            User.IsInRole("Admin") ||
                            User.IsInRole("Vendedor")
                        )
                        {
                            <li class="nav-item">

                                <a class="nav-link text-white"
                                   asp-controller="Clientes"
                                   asp-action="Index">

                                    Clientes

                                </a>

                            </li>
                        }

                        <!-- ========================================= -->
                        <!-- PROVEEDORES -->
                        <!-- ========================================= -->

                        @if (
                            User.IsInRole("Admin") ||
                            User.IsInRole("Bodeguero")
                        )
                        {
                            <li class="nav-item">

                                <a class="nav-link text-white"
                                   asp-controller="Proveedores"
                                   asp-action="Index">

                                    Proveedores

                                </a>

                            </li>
                        }

                        <!-- ========================================= -->
                        <!-- COMPRAS -->
                        <!-- ========================================= -->

                        @if (
                            User.IsInRole("Admin") ||
                            User.IsInRole("Bodeguero")
                        )
                        {
                            <li class="nav-item dropdown">

                                <a class="nav-link dropdown-toggle text-white"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown">

                                    Compras

                                </a>

                                <ul class="dropdown-menu">

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Compras"
                                           asp-action="Index">

                                            Registrar Compra

                                        </a>

                                    </li>

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Compras"
                                           asp-action="Historial">

                                            Historial Compras

                                        </a>

                                    </li>

                                </ul>

                            </li>
                        }

                        <!-- ========================================= -->
                        <!-- VENTAS -->
                        <!-- ========================================= -->

                        @if (
                            User.IsInRole("Admin") ||
                            User.IsInRole("Vendedor")
                        )
                        {
                            <li class="nav-item dropdown">

                                <a class="nav-link dropdown-toggle text-white"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown">

                                    Ventas

                                </a>

                                <ul class="dropdown-menu">

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Ventas"
                                           asp-action="Index">

                                            Registrar Venta

                                        </a>

                                    </li>

                                    <li>

                                        <a class="dropdown-item"
                                           asp-controller="Ventas"
                                           asp-action="Historial">

                                            Historial Ventas

                                        </a>

                                    </li>

                                </ul>

                            </li>
                        }

                    <!-- ========================================= -->
                    <!-- REPORTERIA -->
                    <!-- ========================================= -->
                            @if (User.IsInRole("Admin"))
                            {
                               
                                <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                📊 Reportes
                            </a>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Reportes" asp-action="vw_ProductosBajoStock">
                                        📦 Productos bajo stock
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Reportes" asp-action="vw_VentasPorMes">
                                        📅 Ventas por mes
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Reportes" asp-action="vw_ProductosMasVendidos">
                                        🏆 Productos más vendidos
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Reportes" asp-action="vw_RentabilidadProducto">
                                        💰 Rentabilidad por producto
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Reportes" asp-action="vw_ComprasPorProveedor">
                                        🚚 Compras por proveedor
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Reportes" asp-action="vw_MovimientosInventario">
                                        🔄 Movimientos de inventario
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Reportes" asp-action="vw_ProductosSinMovimiento">
                                        ⚠️ Productos sin movimiento
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Reportes" asp-action="vw_ActividadUsuarios">
                                        👥 Actividad de usuarios
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Reportes" asp-action="vw_ValorizacionInventario">
                                        🗂️ Valorización del inventario
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Reportes" asp-action="vw_ComparativoCompraVenta">
                                        📊 Comparativo compra vs venta
                                    </a>
                                </li>
                            </ul>
                        </li>
                            
                            }    
                            
                    </ul>

                    <!-- ========================================= -->
                    <!-- MENÚ DERECHA -->
                    <!-- ========================================= -->

                    <ul class="navbar-nav">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">

                                <span class="nav-link text-light fw-bold">

                                    Usuario:
                                    @User.Identity.Name

                                </span>

                            </li>

                            <li class="nav-item">

                                <span class="nav-link text-info">

                                    Rol:
                                    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value

                                </span>

                            </li>

                            <li class="nav-item">

                                <a class="nav-link text-danger"
                                   asp-controller="Account"
                                   asp-action="Logout">

                                    Cerrar Sesión

                                </a>

                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <!-- ========================================= -->
    <!-- CONTENIDO -->
    <!-- ========================================= -->

    <div class="container">

        <main role="main"
              class="pb-3">

            @RenderBody()

        </main>

    </div>

    <!-- ========================================= -->
    <!-- FOOTER -->
    <!-- ========================================= -->

    <footer class="border-top footer text-muted">

        <div class="container">

            &copy; 2026 - Inventario & Ventas SV

        </div>

    </footer>

    <!-- ========================================= -->
    <!-- SCRIPTS -->
    <!-- ========================================= -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>