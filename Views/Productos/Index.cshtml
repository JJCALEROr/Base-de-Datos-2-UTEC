@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@section Scripts {
    <script>
        // Ocultar automáticamente las alertas después de 5 segundos
        setTimeout(function () {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function (alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 1000);
    </script>
}


@model IEnumerable<InventarioVentasMVC.Models.Producto>
@{
    ViewData["Title"] = "Productos";
}

<h2>Listado de Productos</h2>

<form asp-controller="Productos" asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Buscar por nombre..." />
        <button type="submit" class="btn btn-primary">Buscar</button>
    </div>
</form>
<div>
    <a asp-action="Create" class="btn btn-primary">Nuevo Producto</a>

    <a asp-controller="Reportes" asp-action="ExportarProductos" class="btn btn-success">
        <i class="bi bi-file-earmark-excel"></i> Exportar Excel
    </a>
</div>
<br />
<table class="table table-hover table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Precio Compra</th>
            <th>Precio Venta</th>
            <th>Stock</th>
            <th>Stock Mínimo</th>
            <th>Activo</th>
            <th>Fecha Creación</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Codigo</td>
                <td>@item.Nombre</td>
                <td>@item.Descripcion</td>
                <td>@item.PrecioCompra.ToString("C")</td>
                <td>@item.PrecioVenta.ToString("C")</td>
                <td>@item.Stock</td>
                <td>@item.StockMinimo</td>
                <td>@(item.Activo ? "Sí" : "No")</td>
                <td>@item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ProductoId" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.ProductoId" class="btn btn-sm btn-info">Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.ProductoId" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>



