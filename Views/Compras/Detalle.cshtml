@model InventarioVentasMVC.Models.Compra

@{
    ViewData["Title"] = "Detalle Compra";
}

<h2>Detalle Compra</h2>

<hr />

<div class="row">

    <div class="col-md-6">

        <table class="table table-bordered">

            <tr>

                <th>Compra</th>

                <td>
                    @Model.CompraId
                </td>

            </tr>

            <tr>

                <th>Fecha</th>

                <td>
                    @Model.Fecha.ToString("dd/MM/yyyy HH:mm")
                </td>

            </tr>

            <tr>

                <th>Proveedor</th>

                <td>
                    @Model.Proveedor.RazonSocial
                </td>

            </tr>

            <tr>

                <th>Usuario</th>

                <td>
                    @Model.Usuario.Username
                </td>

            </tr>

        </table>

    </div>

</div>

<hr />

<h4>Productos</h4>

<table class="table table-striped table-bordered">

    <thead>

        <tr>

            <th>Producto</th>

            <th>Cantidad</th>

            <th>Precio</th>

            <th>Subtotal</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model.DetalleCompras)
        {
            <tr>

                <td>
                    @item.Producto.Nombre
                </td>

                <td>
                    @item.Cantidad
                </td>

                <td>
                    $@item.PrecioUnitario
                </td>

                <td>
                    $@item.Subtotal
                </td>

            </tr>
        }

    </tbody>

</table>

<div class="text-end">

    <h4>

        Total Compra:
        $@Model.Total

    </h4>

</div>

<a asp-action="Historial"
   class="btn btn-secondary">

    Volver

</a>
