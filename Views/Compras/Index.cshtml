@model InventarioVentasMVC.ViewModels.CompraViewModel

@{
    ViewData["Title"] = "Registrar Compra";
}

<h2>Registrar Compra</h2>

<hr />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<!-- ===================================================== -->
<!-- FORMULARIO PRINCIPAL -->
<!-- ===================================================== -->

<form asp-action="GuardarCompra" method="post">

    <div class="row">

        <div class="col-md-4">

            <label class="form-label">
                Proveedor
            </label>

            <select asp-for="ProveedorId"
                    id="proveedorSelect"
                    class="form-select"
                    asp-items="ViewBag.ProveedorId">

                <option value="">
                    -- Seleccione proveedor --
                </option>

            </select>

        </div>

        <div class="col-md-4">

            <label class="form-label">
                Usuario
            </label>

            <select asp-for="UsuarioId"
                    class="form-select"
                    asp-items="ViewBag.UsuarioId">

                <option value="">
                    -- Seleccione usuario --
                </option>

            </select>

        </div>

        <div class="col-md-4">

            <label class="form-label">
                Observaciones
            </label>

            <input asp-for="Observaciones"
                   class="form-control" />

        </div>

    </div>

    <hr />

    <h4>Carrito</h4>

    <table class="table table-bordered">

        <thead>

            <tr>

                <th>Producto</th>
                <th>Cantidad</th>
                <th>Precio Compra</th>
                <th>Subtotal</th>
                <th></th>

            </tr>

        </thead>

        <tbody>

            @if (Model.Carrito.Any())
            {
                @foreach (var item in Model.Carrito)
                {
                    <tr>

                        <td>
                            @item.Producto
                        </td>

                        <td>
                            @item.Cantidad
                        </td>

                        <td>
                            $@item.PrecioCompra
                        </td>

                        <td>
                            $@item.Subtotal
                        </td>

                        <td>

                            <a asp-action="EliminarProducto"
                               asp-route-productoId="@item.ProductoId"
                               class="btn btn-danger btn-sm">

                                Eliminar

                            </a>

                        </td>

                    </tr>
                }
            }
            else
            {
                <tr>

                    <td colspan="5"
                        class="text-center">

                        No hay productos agregados.

                    </td>

                </tr>
            }

        </tbody>

    </table>

    @if (Model.Carrito.Any())
    {
        <div class="text-end">

            <h4>

                Total Compra:
                $@Model.Carrito.Sum(x => x.Subtotal)

            </h4>

        </div>

        <button type="submit"
                class="btn btn-success">

            Finalizar Compra

        </button>
    }

</form>

<hr />

<!-- ===================================================== -->
<!-- FORMULARIO AGREGAR PRODUCTO -->
<!-- ===================================================== -->

<h4>Agregar Producto</h4>

<form asp-action="AgregarProducto" method="post">

    <!-- DATOS TEMPORALES -->
    <input type="hidden"
           name="proveedorId"
           value="@Model.ProveedorId" />

    <input type="hidden"
           name="usuarioId"
           value="@Model.UsuarioId" />

    <input type="hidden"
           name="observaciones"
           value="@Model.Observaciones" />

    <div class="row">

        <div class="col-md-4">

            <label class="form-label">
                Producto
            </label>

            <select name="productoId"
                    id="productoSelect"
                    class="form-select">

                <option value="">
                    -- Seleccione proveedor primero --
                </option>

                @foreach (var producto in ViewBag.Productos)
                {
                    <option value="@producto.ProductoId">

                        @producto.Nombre
                        | Stock: @producto.Stock
                        | Compra: $@producto.PrecioCompra

                    </option>
                }

            </select>

        </div>

        <div class="col-md-2">

            <label class="form-label">
                Cantidad
            </label>

            <input type="number"
                   name="cantidad"
                   class="form-control"
                   min="1"
                   value="1" />

        </div>

        <div class="col-md-3">

            <label class="form-label">
                Precio Compra
            </label>

            <input type="number"
                   step="0.01"
                   name="precioCompra"
                   class="form-control"
                   min="0.01" />

        </div>

        <div class="col-md-3 d-flex align-items-end">

            <button type="submit"
                    class="btn btn-primary w-100">

                Agregar Producto

            </button>

        </div>

    </div>

</form>

@section Scripts {

    <script>

        document
            .getElementById("proveedorSelect")
            .addEventListener("change", function () {

                let proveedorId = this.value;

                let productoSelect =
                    document.getElementById("productoSelect");

                if (proveedorId === "") {

                    productoSelect.innerHTML =
                        '<option value="">-- Seleccione proveedor primero --</option>';

                    return;
                }

                productoSelect.innerHTML =
                    '<option value="">Cargando productos...</option>';

                fetch('/Compras/ObtenerProductosPorProveedor?proveedorId='
                    + proveedorId)

                    .then(response => response.json())

                    .then(data => {

                        productoSelect.innerHTML =
                            '<option value="">-- Seleccione producto --</option>';

                        if (data.length === 0) {

                            productoSelect.innerHTML =
                                '<option value="">No hay productos para este proveedor</option>';

                            return;
                        }

                        data.forEach(producto => {

                            productoSelect.innerHTML += `
                                <option value="${producto.productoId}">
                                    ${producto.nombre}
                                    | Stock: ${producto.stock}
                                    | Compra: $${producto.precioCompra}
                                </option>
                            `;
                        });

                    })

                    .catch(error => {

                        productoSelect.innerHTML =
                            '<option value="">Error cargando productos</option>';

                        console.error(error);

                    });

            });

    </script>

}