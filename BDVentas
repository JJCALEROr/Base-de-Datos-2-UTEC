-- --------------------------------------------------------
-- SP 6: B�squeda de productos
-- --------------------------------------------------------
CREATE OR ALTER PROCEDURE sp_BuscarProductos
    @Termino    NVARCHAR(100) = NULL,
    @CategoriaId INT = NULL,
    @SoloActivos BIT = 1
AS
BEGIN
    SET NOCOUNT ON;
    SELECT *
    FROM vw_ProductosDetalle
    WHERE (@Termino     IS NULL OR Producto LIKE '%' + @Termino + '%'
                                OR Codigo   LIKE '%' + @Termino + '%')
      AND (@CategoriaId IS NULL OR CategoriaId = @CategoriaId)
      AND (@SoloActivos = 0    OR Activo = 1)
    ORDER BY Producto;
END;
GO
 
-- --------------------------------------------------------
-- SP 7: Dashboard - KPIs del d�a
-- --------------------------------------------------------
CREATE OR ALTER PROCEDURE sp_DashboardHoy
AS
BEGIN
    SET NOCOUNT ON;
    DECLARE @Hoy DATE = CAST(GETDATE() AS DATE);
 
    SELECT
        (SELECT COUNT(*) FROM Ventas
         WHERE CAST(Fecha AS DATE) = @Hoy AND Estado='Completada')  AS VentasHoy,
        (SELECT ISNULL(SUM(Total),0) FROM Ventas
         WHERE CAST(Fecha AS DATE) = @Hoy AND Estado='Completada')  AS IngresoHoy,
        (SELECT COUNT(*) FROM vw_ProductosStockBajo)                AS ProductosStockBajo,
        (SELECT COUNT(*) FROM Productos WHERE Activo=1)             AS TotalProductos,
        (SELECT COUNT(*) FROM Clientes  WHERE Activo=1)             AS TotalClientes;
END;
GO


