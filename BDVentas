-- --------------------------------------------------------
-- Vista 1: Productos con categor�a, proveedor y estado stock
-- --------------------------------------------------------
CREATE OR ALTER VIEW vw_ProductosDetalle AS
SELECT
    p.ProductoId,
    p.Codigo,
    p.Nombre                         AS Producto,
    c.Nombre                         AS Categoria,
    pr.RazonSocial                   AS Proveedor,
    p.PrecioCompra,
    p.PrecioVenta,
    p.Stock,
    p.StockMinimo,
    CASE
        WHEN p.Stock = 0             THEN 'Sin Stock'
        WHEN p.Stock <= p.StockMinimo THEN 'Stock Bajo'
        ELSE 'Disponible'
    END                              AS EstadoStock,
    p.Activo,
    p.FechaCreacion
FROM Productos p
INNER JOIN Categorias  c  ON p.CategoriaId  = c.CategoriaId
INNER JOIN Proveedores pr ON p.ProveedorId  = pr.ProveedorId;
GO
 
-- --------------------------------------------------------
-- Vista 2: Ventas con cliente y usuario
-- --------------------------------------------------------
CREATE OR ALTER VIEW vw_VentasDetalle AS
SELECT
    v.VentaId,
    v.NumeroVenta,
    v.Fecha,
    c.ClienteId,
    c.Nombre + ' ' + c.Apellido     AS Cliente,
    c.DUI,
    u.Nombre + ' ' + u.Apellido     AS Vendedor,
    v.Subtotal,
    v.Descuento,
    v.IVA,
    v.Total,
    v.Estado,
    v.Observaciones
FROM Ventas v
INNER JOIN Clientes  c ON v.ClienteId  = c.ClienteId
INNER JOIN Usuarios  u ON v.UsuarioId  = u.UsuarioId;
GO
 
-- --------------------------------------------------------
-- Vista 3: Detalle de ventas completo
-- --------------------------------------------------------
CREATE OR ALTER VIEW vw_DetalleVentasCompleto AS
SELECT
    dv.DetalleId,
    v.NumeroVenta,
    v.Fecha,
    c.Nombre + ' ' + c.Apellido     AS Cliente,
    p.Codigo                         AS CodigoProducto,
    p.Nombre                         AS Producto,
    cat.Nombre                       AS Categoria,
    dv.Cantidad,
    dv.PrecioUnitario,
    dv.Descuento,
    dv.Subtotal,
    v.Estado
FROM DetalleVentas  dv
INNER JOIN Ventas    v   ON dv.VentaId    = v.VentaId
INNER JOIN Productos p   ON dv.ProductoId = p.ProductoId
INNER JOIN Clientes  c   ON v.ClienteId   = c.ClienteId
INNER JOIN Categorias cat ON p.CategoriaId = cat.CategoriaId;
GO
 
-- --------------------------------------------------------
-- Vista 4: Resumen de ventas por d�a
-- --------------------------------------------------------
CREATE OR ALTER VIEW vw_VentasPorDia AS
SELECT
    CAST(v.Fecha AS DATE)           AS Dia,
    COUNT(v.VentaId)                AS TotalVentas,
    SUM(v.Total)                    AS MontoTotal,
    SUM(v.Descuento)                AS TotalDescuentos,
    AVG(v.Total)                    AS PromedioVenta
FROM Ventas v
WHERE v.Estado = 'Completada'
GROUP BY CAST(v.Fecha AS DATE);
GO
 
-- --------------------------------------------------------
-- Vista 5: Productos con stock bajo
-- --------------------------------------------------------
CREATE OR ALTER VIEW vw_ProductosStockBajo AS
SELECT
    p.ProductoId,
    p.Codigo,
    p.Nombre,
    c.Nombre  AS Categoria,
    pr.RazonSocial AS Proveedor,
    pr.Email  AS EmailProveedor,
    p.Stock,
    p.StockMinimo,
    (p.StockMinimo - p.Stock) AS CantidadFaltante
FROM Productos p
INNER JOIN Categorias  c  ON p.CategoriaId  = c.CategoriaId
INNER JOIN Proveedores pr ON p.ProveedorId  = pr.ProveedorId
WHERE p.Stock <= p.StockMinimo
  AND p.Activo = 1;
GO
 
-- --------------------------------------------------------
-- Vista 6: Top productos m�s vendidos
-- --------------------------------------------------------
CREATE OR ALTER VIEW vw_TopProductosVendidos AS
SELECT TOP 100
    p.ProductoId,
    p.Codigo,
    p.Nombre                        AS Producto,
    c.Nombre                        AS Categoria,
    SUM(dv.Cantidad)                AS TotalUnidades,
    SUM(dv.Subtotal)                AS TotalIngresos,
    COUNT(DISTINCT v.VentaId)       AS NumeroVentas
FROM DetalleVentas dv
INNER JOIN Ventas     v   ON dv.VentaId    = v.VentaId
INNER JOIN Productos  p   ON dv.ProductoId = p.ProductoId
INNER JOIN Categorias c   ON p.CategoriaId = c.CategoriaId
WHERE v.Estado = 'Completada'
GROUP BY p.ProductoId, p.Codigo, p.Nombre, c.Nombre
ORDER BY TotalUnidades DESC;
GO
 
-- --------------------------------------------------------
-- Vista 7: Resumen por categor�a
-- --------------------------------------------------------
CREATE OR ALTER VIEW vw_ResumenCategorias AS
SELECT
    c.CategoriaId,
    c.Nombre                        AS Categoria,
    COUNT(p.ProductoId)             AS TotalProductos,
    SUM(p.Stock)                    AS StockTotal,
    SUM(p.Stock * p.PrecioVenta)    AS ValorInventario,
    AVG(p.PrecioVenta)              AS PrecioPromedio
FROM Categorias c
LEFT JOIN Productos p ON c.CategoriaId = p.CategoriaId AND p.Activo = 1
GROUP BY c.CategoriaId, c.Nombre;
GO

-- --------------------------------------------------------
-- SP 1: Registrar Venta completa (encabezado + detalle)
-- --------------------------------------------------------
CREATE OR ALTER PROCEDURE sp_RegistrarVenta
    @ClienteId     INT,
    @UsuarioId     INT,
    @Descuento     DECIMAL(18,2),
    @Observaciones NVARCHAR(500),
    @Detalle       NVARCHAR(MAX),   -- JSON: [{ProductoId, Cantidad, PrecioUnitario, Descuento}]
    @VentaId       INT OUTPUT,
    @NumeroVenta   NVARCHAR(20) OUTPUT,
    @Mensaje       NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;
 
        -- Generar n�mero de venta
        SET @NumeroVenta = 'VTA-' + FORMAT(GETDATE(), 'yyyyMMdd') +
                           RIGHT('0000' + CAST((
                               SELECT ISNULL(MAX(VentaId),0)+1 FROM Ventas
                           ) AS NVARCHAR), 4);
 
        -- Parsear detalle desde JSON
        DECLARE @DetalleTemp TABLE (
            ProductoId     INT,
            Cantidad       INT,
            PrecioUnitario DECIMAL(18,2),
            Descuento      DECIMAL(18,2)
        );
 
        INSERT INTO @DetalleTemp
        SELECT
            JSON_VALUE(j.value, '$.ProductoId'),
            JSON_VALUE(j.value, '$.Cantidad'),
            JSON_VALUE(j.value, '$.PrecioUnitario'),
            JSON_VALUE(j.value, '$.Descuento')
        FROM OPENJSON(@Detalle) j;
 
        -- Validar stock
        IF EXISTS (
            SELECT 1 FROM @DetalleTemp dt
            INNER JOIN Productos p ON dt.ProductoId = p.ProductoId
            WHERE p.Stock < dt.Cantidad
        )
        BEGIN
            ROLLBACK;
            SET @Mensaje = 'ERROR: Stock insuficiente para uno o m�s productos.';
            RETURN;
        END
 
        -- Calcular subtotal
        DECLARE @Subtotal DECIMAL(18,2);
        SELECT @Subtotal = SUM((Cantidad * PrecioUnitario) - Descuento)
        FROM @DetalleTemp;
 
        DECLARE @IVA      DECIMAL(18,2) = @Subtotal * 0.13;
        DECLARE @Total    DECIMAL(18,2) = @Subtotal - @Descuento + @IVA;
 
        -- Insertar encabezado venta
        INSERT INTO Ventas (ClienteId, UsuarioId, NumeroVenta, Subtotal, Descuento, IVA, Total, Observaciones)
        VALUES (@ClienteId, @UsuarioId, @NumeroVenta, @Subtotal, @Descuento, @IVA, @Total, @Observaciones);
 
        SET @VentaId = SCOPE_IDENTITY();
 
        -- Insertar detalle y descontar stock
        INSERT INTO DetalleVentas (VentaId, ProductoId, Cantidad, PrecioUnitario, Descuento, Subtotal)
        SELECT
            @VentaId,
            dt.ProductoId,
            dt.Cantidad,
            dt.PrecioUnitario,
            dt.Descuento,
            (dt.Cantidad * dt.PrecioUnitario) - dt.Descuento
        FROM @DetalleTemp dt;
 
        -- Actualizar stock (el trigger TR_RegistrarMovimientoSalida lo registra)
        UPDATE p
        SET p.Stock = p.Stock - dt.Cantidad
        FROM Productos p
        INNER JOIN @DetalleTemp dt ON p.ProductoId = dt.ProductoId;
 
        COMMIT;
        SET @Mensaje = 'OK: Venta registrada correctamente.';
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @Mensaje = 'ERROR: ' + ERROR_MESSAGE();
    END CATCH
END;
GO
 
-- --------------------------------------------------------
-- SP 2: Anular venta (restaura stock)
-- --------------------------------------------------------
CREATE OR ALTER PROCEDURE sp_AnularVenta
    @VentaId  INT,
    @Mensaje  NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;
 
        IF NOT EXISTS (SELECT 1 FROM Ventas WHERE VentaId = @VentaId AND Estado = 'Completada')
        BEGIN
            ROLLBACK;
            SET @Mensaje = 'ERROR: Venta no encontrada o ya anulada.';
            RETURN;
        END
 
        -- Restaurar stock
        UPDATE p
        SET p.Stock = p.Stock + dv.Cantidad
        FROM Productos p
        INNER JOIN DetalleVentas dv ON p.ProductoId = dv.ProductoId
        WHERE dv.VentaId = @VentaId;
 
        -- Cambiar estado
        UPDATE Ventas SET Estado = 'Anulada' WHERE VentaId = @VentaId;
 
        COMMIT;
        SET @Mensaje = 'OK: Venta anulada y stock restaurado.';
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @Mensaje = 'ERROR: ' + ERROR_MESSAGE();
    END CATCH
END;
GO
 
-- --------------------------------------------------------
-- SP 3: Registrar Compra (entrada de inventario)
-- --------------------------------------------------------
CREATE OR ALTER PROCEDURE sp_RegistrarCompra
    @ProveedorId   INT,
    @UsuarioId     INT,
    @Observaciones NVARCHAR(500),
    @Detalle       NVARCHAR(MAX),  -- JSON
    @CompraId      INT OUTPUT,
    @Mensaje       NVARCHAR(200) OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;
 
        DECLARE @NumeroCompra NVARCHAR(20) =
            'CMP-' + FORMAT(GETDATE(),'yyyyMMdd') +
            RIGHT('0000' + CAST((SELECT ISNULL(MAX(CompraId),0)+1 FROM Compras) AS NVARCHAR),4);
 
        DECLARE @DetalleTemp TABLE (
            ProductoId     INT,
            Cantidad       INT,
            PrecioUnitario DECIMAL(18,2)
        );
 
        INSERT INTO @DetalleTemp
        SELECT
            JSON_VALUE(j.value,'$.ProductoId'),
            JSON_VALUE(j.value,'$.Cantidad'),
            JSON_VALUE(j.value,'$.PrecioUnitario')
        FROM OPENJSON(@Detalle) j;
 
        DECLARE @Total DECIMAL(18,2);
        SELECT @Total = SUM(Cantidad * PrecioUnitario) FROM @DetalleTemp;
 
        INSERT INTO Compras (ProveedorId, UsuarioId, NumeroCompra, Total, Observaciones)
        VALUES (@ProveedorId, @UsuarioId, @NumeroCompra, @Total, @Observaciones);
 
        SET @CompraId = SCOPE_IDENTITY();
 
        INSERT INTO DetalleCompras (CompraId, ProductoId, Cantidad, PrecioUnitario, Subtotal)
        SELECT @CompraId, ProductoId, Cantidad, PrecioUnitario, Cantidad * PrecioUnitario
        FROM @DetalleTemp;
 
        -- Actualizar stock
        UPDATE p
        SET p.Stock = p.Stock + dt.Cantidad,
            p.PrecioCompra = dt.PrecioUnitario
        FROM Productos p
        INNER JOIN @DetalleTemp dt ON p.ProductoId = dt.ProductoId;
 
        COMMIT;
        SET @Mensaje = 'OK: Compra registrada y stock actualizado.';
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK;
        SET @Mensaje = 'ERROR: ' + ERROR_MESSAGE();
    END CATCH
END;
GO
 
-- --------------------------------------------------------
-- SP 4: Reporte de ventas por rango de fechas
-- --------------------------------------------------------
CREATE OR ALTER PROCEDURE sp_ReporteVentas
    @FechaInicio DATE,
    @FechaFin    DATE,
    @ClienteId   INT = NULL,
    @UsuarioId   INT = NULL,
    @Estado      NVARCHAR(20) = NULL
AS
BEGIN
    SET NOCOUNT ON;
    SELECT
        v.NumeroVenta,
        v.Fecha,
        c.Nombre + ' ' + c.Apellido AS Cliente,
        u.Nombre + ' ' + u.Apellido AS Vendedor,
        v.Subtotal,
        v.Descuento,
        v.IVA,
        v.Total,
        v.Estado
    FROM Ventas v
    INNER JOIN Clientes c ON v.ClienteId = c.ClienteId
    INNER JOIN Usuarios u ON v.UsuarioId = u.UsuarioId
    WHERE CAST(v.Fecha AS DATE) BETWEEN @FechaInicio AND @FechaFin
      AND (@ClienteId IS NULL OR v.ClienteId = @ClienteId)
      AND (@UsuarioId IS NULL OR v.UsuarioId = @UsuarioId)
      AND (@Estado    IS NULL OR v.Estado    = @Estado)
    ORDER BY v.Fecha DESC;
END;
GO
 
