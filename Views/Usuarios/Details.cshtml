@model InventarioVentasMVC.Models.Usuario

@{
    ViewData["Title"] = "Detalles del Usuario";
}

<h1>Detalles del Usuario</h1>

<hr />

<div>

    <dl class="row">

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Nombre)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Nombre)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Apellido)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Apellido)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Username)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Username)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Rol)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Rol)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Activo)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Activo)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.FechaCreacion)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.FechaCreacion)
        </dd>

    </dl>

    <div class="mt-3">

        <a asp-action="Edit"
           asp-route-id="@Model.UsuarioId"
           class="btn btn-warning">
            Editar
        </a>

        <a asp-action="Index"
           class="btn btn-secondary">
            Volver al listado
        </a>

    </div>

</div>